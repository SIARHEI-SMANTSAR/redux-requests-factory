{
  "name": "redux-requests-factory",
  "version": "1.4.0",
  "description": "Redux requests factory",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsup --watch",
    "build": "tsup && tsc --project tsconfig.build.json",
    "test": "jest",
    "check:types": "tsc --noEmit",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "lint": "npm run check:types && npm run check:format",
    "prepare": "npm run build"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "endOfLine": "auto"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SIARHEI-SMANTSAR/redux-requests-factory.git"
  },
  "keywords": [
    "redux",
    "api",
    "middleware",
    "requests",
    "requests-factory",
    "api-factory",
    "redux-middleware",
    "flux"
  ],
  "author": {
    "name": "Siarhei Smantsar",
    "email": "siarhei.smantsar@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SIARHEI-SMANTSAR/redux-requests-factory/issues"
  },
  "homepage": "https://github.com/SIARHEI-SMANTSAR/redux-requests-factory#readme",
  "peerDependencies": {
    "redux": "^4 || ^5"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@swc/core": "^1.15.46",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.memoize": "^4.1.9",
    "@types/node": "^26.1.1",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "redux": "^5.0.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "lodash.debounce": "^4.0.8",
    "lodash.memoize": "^4.1.2",
    "reselect": "^5.2.0"
  }
}
